/// Persistent outbox queue for webhook events (Issue #338).
model WebhookEvent {
  id          String   @id @default(uuid()) @db.VarChar(36)
  realmId     String   @map("realm_id") @db.VarChar(36)
  eventType   String   @map("event_type")
